       IDENTIFICATION DIVISION.
       PROGRAM-ID. NUMEDCOM.

       ENVIRONMENT DIVISION.
       CONFIGURATION SECTION.
       SPECIAL-NAMES.
           DECIMAL-POINT IS COMMA.

       DATA DIVISION.
       WORKING-STORAGE SECTION.

       01  TEST-COUNTERS.
           05 TESTS-RUN              PIC 9(4) VALUE 0.
           05 TESTS-PASSED           PIC 9(4) VALUE 0.
           05 TESTS-FAILED           PIC 9(4) VALUE 0.

       01  TEST-CONTEXT.
           05 TEST-ID                PIC X(8)  VALUE SPACES.
           05 TEST-NAME              PIC X(60) VALUE SPACES.
           05 ACTUAL-RESULT          PIC X(80) VALUE SPACES.
           05 EXPECTED-RESULT        PIC X(80) VALUE SPACES.

       01  NUMERIC-SOURCES.
           05 SRC-U4                 PIC 9(4)       VALUE ZERO.
           05 SRC-U5                 PIC 9(5)       VALUE ZERO.
           05 SRC-U8                 PIC 9(8)       VALUE ZERO.
           05 SRC-S4                 PIC S9(4)      VALUE ZERO.
           05 SRC-S5                 PIC S9(5)      VALUE ZERO.
           05 SRC-U5V2               PIC 9(5)V99    VALUE ZERO.
           05 SRC-S5V2               PIC S9(5)V99   VALUE ZERO.

           05 SRC-LEAD-SEP           PIC S9(4)
                                      SIGN LEADING SEPARATE
                                      VALUE ZERO.

           05 SRC-TRAIL-SEP          PIC S9(4)
                                      SIGN TRAILING SEPARATE
                                      VALUE ZERO.

           05 SRC-COMP               PIC S9(5)
                                      USAGE COMPUTATIONAL
                                      VALUE ZERO.

           05 SRC-COMP-DEC           PIC S9(5)V99
                                      USAGE COMPUTATIONAL
                                      VALUE ZERO.

           05 SRC-COMP-1             USAGE COMPUTATIONAL-1.
           05 SRC-COMP-2             USAGE COMPUTATIONAL-2.

           05 SRC-COMP-3             PIC S9(5)V99
                                      USAGE COMPUTATIONAL-3
                                      VALUE ZERO.

           05 SRC-COMP-4             PIC S9(5)
                                      USAGE COMPUTATIONAL-4
                                      VALUE ZERO.

           05 SRC-ARITH              PIC S9(7)V99 VALUE ZERO.

       01  EDITED-FIELDS.
           05 E-9999                 PIC 9999.
           05 E-ZZZ9                 PIC ZZZ9.
           05 E-ZZZZ                 PIC ZZZZ.
           05 E-STAR9                PIC ***9.
           05 E-STARS                PIC ****.

           05 E-GROUP-FIX            PIC 9.999.
           05 E-GROUP-Z              PIC ZZ.ZZ9.
           05 E-DEC-FIX              PIC 999,99.
           05 E-DEC-Z                PIC ZZ9,99.

           05 E-PLUS-LEAD            PIC +9999.
           05 E-PLUS-TRAIL           PIC 9999+.
           05 E-MINUS-LEAD           PIC -9999.
           05 E-MINUS-TRAIL          PIC 9999-.

           05 E-CR                   PIC 9999CR.
           05 E-DB                   PIC 9999DB.

           05 E-CURRENCY-FIX         PIC $9999.
           05 E-CURRENCY-FLOAT       PIC $$$$9.
           05 E-PLUS-FLOAT           PIC ++++9.
           05 E-MINUS-FLOAT          PIC ----9.

           05 E-BLANK-INSERT         PIC 99B99.
           05 E-ZERO-INSERT          PIC 9900.
           05 E-SLASH-INSERT         PIC 99/99/9999.

           05 E-COMPLEX-SIGN         PIC $ZZ.ZZ9,99-.
           05 E-COMPLEX-CR           PIC $ZZ.ZZ9,99CR.
           05 E-BLANK-WHEN-ZERO      PIC ZZ9,99
                                      BLANK WHEN ZERO.

       PROCEDURE DIVISION.

       MAIN-PARA.

           DISPLAY "NUMERIC-EDITED PIC TESTS".
           DISPLAY "DECIMAL-POINT IS COMMA".
           DISPLAY "------------------------".

           PERFORM TEST-001-LITERAL-DECIMAL-COMMA.
           PERFORM TEST-002-DISPLAY-DECIMAL-SOURCE.
           PERFORM TEST-003-GROUPING-PERIOD.
           PERFORM TEST-004-ZERO-SUPPRESSION.
           PERFORM TEST-005-STAR-PROTECTION.

