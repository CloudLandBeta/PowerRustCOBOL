           PERFORM TEST-011-LEADING-PLUS-NEG.
           PERFORM TEST-012-TRAILING-PLUS-POS.
           PERFORM TEST-013-TRAILING-PLUS-NEG.

           PERFORM TEST-020-LEADING-MINUS-POS.
           PERFORM TEST-021-LEADING-MINUS-NEG.
           PERFORM TEST-022-TRAILING-MINUS-POS.
           PERFORM TEST-023-TRAILING-MINUS-NEG.

           PERFORM TEST-030-CR-POS.
           PERFORM TEST-031-CR-NEG.
           PERFORM TEST-032-DB-POS.
           PERFORM TEST-033-DB-NEG.

           PERFORM TEST-040-CURRENCY-FIXED.
           PERFORM TEST-041-CURRENCY-FLOAT.
           PERFORM TEST-042-FLOATING-PLUS-POS.
           PERFORM TEST-043-FLOATING-PLUS-NEG.
