           PERFORM TEST-083-COMPLEX-CR-NEGATIVE.
           PERFORM TEST-084-BLANK-WHEN-ZERO.
           PERFORM TEST-085-BLANK-WHEN-NONZERO.

           DISPLAY "------------------------".
           DISPLAY "TESTS RUN    : " TESTS-RUN.
           DISPLAY "TESTS PASSED : " TESTS-PASSED.
           DISPLAY "TESTS FAILED : " TESTS-FAILED.

           IF TESTS-FAILED = ZERO
               DISPLAY "RESULT       : PASS"
           ELSE
               DISPLAY "RESULT       : FAIL"
           END-IF.

           STOP RUN.

       ASSERT-RESULT.

           ADD 1 TO TESTS-RUN.

           IF ACTUAL-RESULT = EXPECTED-RESULT
               ADD 1 TO TESTS-PASSED
               DISPLAY "PASS " TEST-ID " " TEST-NAME
           ELSE
               ADD 1 TO TESTS-FAILED
               DISPLAY "FAIL " TEST-ID " " TEST-NAME
               DISPLAY "     ACTUAL   = [" ACTUAL-RESULT "]"
               DISPLAY "     EXPECTED = [" EXPECTED-RESULT "]"
           END-IF.

       TEST-001-LITERAL-DECIMAL-COMMA.

           MOVE "T001" TO TEST-ID.
           MOVE "NUMERIC LITERAL WITH DECIMAL COMMA" TO TEST-NAME.
           MOVE SPACES TO ACTUAL-RESULT EXPECTED-RESULT.

           MOVE 123,45 TO E-DEC-FIX.
           MOVE E-DEC-FIX TO ACTUAL-RESULT.
           MOVE "123,45" TO EXPECTED-RESULT.

           PERFORM ASSERT-RESULT.

       TEST-002-DISPLAY-DECIMAL-SOURCE.

